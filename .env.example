# =============================================================================
# Matthews Hotel Team — environment variables
# Copy to .env.local for local dev, set in Vercel for production.
# =============================================================================

# HubSpot CRM Contacts (inbound contact pipe)
# ---------------------------------------------------------
# Single-token auth via HubSpot Private App. The route /api/contact creates
# a Contact directly in HubSpot CRM with `website_lead_source =
# "Matthews Hotel Team Website"` and `topic_of_interest` set from the form.
#
# Where to get the token:
#   HubSpot → Settings → Integrations → Private Apps → create or open one
#   → Auth tab → "Access token" (starts with `pat-na2-...`).
#   Required scopes: crm.objects.contacts.read, crm.objects.contacts.write,
#   crm.schemas.contacts.read.
#
# When set:
#   - form submissions create real HubSpot contacts, segmentable via
#     `website_lead_source` and `topic_of_interest` properties.
# When unset:
#   - /api/contact returns 503 HUBSPOT_NOT_CONFIGURED; the form falls back
#     to mailto so the contact path still works.

HUBSPOT_TOKEN=
